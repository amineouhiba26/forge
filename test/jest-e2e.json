{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@forge/contracts(|/.*)$": "<rootDir>/libs/contracts/src/$1",
    "^@forge/prisma(|/.*)$": "<rootDir>/libs/prisma/src/$1",
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^@forge/observability(|/.*)$": "<rootDir>/libs/observability/src/$1"
  },
  "testTimeout": 30000
}
