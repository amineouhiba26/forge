# Copy to .env before running anything: `cp .env.example .env`
# Every var here is validated by Joi at boot — a missing or malformed value
# crashes the app on purpose rather than failing later under load.

NODE_ENV=development

# Gateway HTTP port
PORT=3000

# Redis — microservice transport, and (from Sprint 5) the BullMQ backend
REDIS_HOST=localhost
REDIS_PORT=6379

# Postgres — TWO connection strings, deliberately.
#
# The services connect as `forge_app`: an unprivileged role that is subject to
# Row-Level Security. Postgres exempts superusers from RLS entirely, so
# connecting as the owner would make every tenant-isolation policy inert while
# every query still succeeded — the worst possible failure mode.
DATABASE_URL=postgresql://forge_app:forge_app@localhost:5433/forge?schema=public

# Migrations run as the owner, which needs DDL rights the app must never have.
DATABASE_MIGRATION_URL=postgresql://forge:forge@localhost:5433/forge?schema=public

# JWT — generate your own, these are placeholders:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#
# The two secrets MUST differ. If they match, a refresh token also verifies as
# an access token, and the short access TTL stops meaning anything.
JWT_ACCESS_SECRET=dev-only-access-secret-change-me-0123456789abcdef
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me-fedcba9876543210
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Stripe — billing-service only. Test-mode values from your Stripe dashboard.
# The webhook signing secret is shown when you create the endpoint (or by
# `stripe listen` when developing locally).
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
