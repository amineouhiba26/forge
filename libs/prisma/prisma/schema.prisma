// Sprint 5: adds ProcessedJob and DeadLetterJob for the queue infrastructure.

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  // Prisma 7's generator defaults to ESM, which emits `import.meta.url` and
  // makes Node treat the compiled file as an ES module. Nest's DI and
  // decorator metadata need CommonJS, so pin the format here.
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

// Prisma 7 no longer accepts `url` here. The connection string is supplied at
// runtime through the pg driver adapter (see prisma.service.ts) and to the CLI
// through prisma.config.ts — one less place for a secret to sit in source.
datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  // Drives tax calculation in the Sprint 3 CreateInvoiceCommand.
  country   String   @db.Char(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  clients   Client[]
  contracts Contract[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String
  passwordHash String   @map("password_hash")
  role         UserRole @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  // Email is unique *per tenant*, not globally: the same person may hold an
  // account in two tenants. A global unique here would leak tenant membership
  // via signup errors.
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// One row per issued refresh token, so tokens can be rotated and revoked.
///
/// A JWT is self-contained and cannot be un-issued — the only way to revoke one
/// is to check it against server-side state. That is what this table is for,
/// and it is why refresh tokens are long-lived while access tokens are not:
/// the short access-token TTL bounds how long a revoked session stays usable.
model RefreshToken {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid

  /// SHA-256 of the token, never the token itself. A database leak must not
  /// hand out usable sessions. Hashing is cheap here (unlike passwords)
  /// because the input is already high-entropy — no brute-force to slow down.
  tokenHash String @unique @map("token_hash")

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  /// Set when this token is rotated out, pointing at its replacement. Presenting
  /// an already-rotated token means it leaked, and the whole chain is revoked.
  replacedById String? @unique @map("replaced_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("refresh_tokens")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  COMPLETE
}

/// A person or company the tenant does work for.
model Client {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  name         String
  email        String
  companyName  String? @map("company_name")

  /// Archived rather than deleted: a client referenced by a contract — and,
  /// from Sprint 3, by issued invoices — is part of the tenant's financial
  /// record. Deleting it would orphan documents that must stay reproducible.
  archivedAt DateTime? @map("archived_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contracts Contract[]

  // Scoped to the tenant, not global: two tenants may legitimately work for
  // the same client company.
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, archivedAt])
  @@map("clients")
}

model Contract {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  clientId String @map("client_id") @db.Uuid

  title       String
  description String?
  status      ContractStatus @default(DRAFT)

  /// ISO 4217. Stored per contract because a freelancer may bill clients in
  /// different currencies, and the rate is fixed when the contract is agreed.
  currency String @default("EUR") @db.Char(3)

  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  milestones Milestone[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([clientId])
  @@map("contracts")
}

/// A deliverable within a contract. Sprint 3 turns a completed milestone into
/// an invoice, which is why `amount` lives here rather than on the contract.
model Milestone {
  id         String @id @default(uuid()) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  contractId String @map("contract_id") @db.Uuid

  title String

  /// Decimal, never Float. Binary floating point cannot represent 0.1
  /// exactly, and rounding drift in money is a real defect — 12,2 gives exact
  /// arithmetic up to 9,999,999,999.99.
  amount Decimal @db.Decimal(12, 2)

  dueDate DateTime        @map("due_date") @db.Date
  status  MilestoneStatus @default(PENDING)

  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contractId])
  @@index([contractId, status])
  @@map("milestones")
}

enum InvoiceStatus {
  /// Created, PDF not yet produced. The state every invoice starts in.
  PENDING
  /// PDF generated successfully; the invoice can be sent and paid.
  ISSUED
  /// The saga's compensating state — PDF generation failed and a retry is queued.
  GENERATION_FAILED
  /// Sprint 4: a Stripe payment succeeded against this invoice.
  PAID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model Invoice {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  contractId  String @map("contract_id") @db.Uuid
  clientId    String @map("client_id") @db.Uuid

  /// One invoice per milestone, enforced by the database rather than by a
  /// check in the command handler. Two concurrent CreateInvoiceCommands for
  /// the same milestone would both pass an application-level "already
  /// invoiced?" read; only a unique constraint actually prevents the double.
  milestoneId String @unique @map("milestone_id") @db.Uuid

  /// The milestone amount at the time of invoicing. Copied rather than joined:
  /// an invoice is a financial document and must stay reproducible even if the
  /// milestone is later edited.
  subtotal Decimal @db.Decimal(12, 2)

  /// Rate as a percentage (20.00 = 20%), resolved from the tenant's country.
  taxRate   Decimal @map("tax_rate") @db.Decimal(5, 2)
  taxAmount Decimal @map("tax_amount") @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  currency String @db.Char(3)

  status InvoiceStatus @default(PENDING)

  /// Set when the worker reports a successful PDF render.
  pdfUrl String? @map("pdf_url")

  /// The Stripe PaymentIntent this invoice is collected through. Unique so a
  /// second intent cannot be silently attached to the same invoice.
  stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")

  /// Recorded when a payment attempt fails. The invoice stays PENDING/ISSUED —
  /// a failed attempt is not a state of the invoice, it is a fact about one
  /// attempt — but the reason has to be visible to whoever chases it.
  lastPaymentError String? @map("last_payment_error")

  /// Why generation failed, so a retry is diagnosable rather than mysterious.
  failureReason String? @map("failure_reason")
  /// Bounded so a permanently failing invoice cannot retry forever.
  generationAttempts Int @default(0) @map("generation_attempts")

  issuedAt DateTime? @map("issued_at")
  paidAt   DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payments Payment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([contractId])
  @@map("invoices")
}

/// Sprint 4 populates this from Stripe webhooks. Created now because the
/// backlog asks for both models in one migration, and because the invoice
/// relation is easier to add up front than to bolt on later.
model Payment {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  invoiceId String @map("invoice_id") @db.Uuid

  provider          String @default("stripe")
  /// The provider's own ID, unique so a replayed webhook cannot create a
  /// second Payment row for the same real-world payment.
  providerPaymentId String @unique @map("provider_payment_id")

  amount   Decimal @db.Decimal(12, 2)
  currency String  @db.Char(3)

  status        PaymentStatus @default(PENDING)
  failureReason String?       @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([invoiceId])
  @@map("payments")
}

/// Every Stripe webhook event this system has already acted on.
///
/// The entire idempotency guarantee rests on the unique constraint here, and
/// on the row being inserted **in the same transaction** as the state change it
/// authorises. Checking "have I seen this?" and then acting is two statements,
/// and two concurrent deliveries of the same event both read "no" before
/// either writes.
///
/// Deliberately *not* tenant-scoped, and deliberately without RLS: Stripe event
/// IDs are unique per account, not per tenant. A per-tenant unique index would
/// let one event be processed once under each tenant, which is the exact double
/// application this table exists to prevent.
model ProcessedWebhook {
  id String @id @default(uuid()) @db.Uuid

  /// Stripe's own event ID (`evt_...`).
  eventId String @unique @map("event_id")
  /// e.g. `payment_intent.succeeded`. Stored for diagnostics only.
  eventType String @map("event_type")

  /// Recorded where known, so a replay can be traced to a tenant. Never used
  /// for filtering — see the note above about global uniqueness.
  tenantId String? @map("tenant_id") @db.Uuid

  processedAt DateTime @default(now()) @map("processed_at")

  @@index([eventType])
  @@map("processed_webhooks")
}

enum JobState {
  /// Taken by a worker, not yet finished.
  CLAIMED
  /// Finished successfully. The side effect has happened.
  COMPLETED
}

/// Job-level idempotency, so a reprocessed job does not repeat its side effect.
///
/// BullMQ can deliver a job more than once: a worker that crashes after doing
/// the work but before acknowledging leaves the job to be retried. For a PDF
/// render that is harmless (same bytes, same path). For an email it means a
/// client receives the same invoice twice.
///
/// Not tenant-scoped and no RLS, for the same reason as ProcessedWebhook: the
/// key must be globally unique to be a dedupe key at all.
model ProcessedJob {
  id String @id @default(uuid()) @db.Uuid

  /// Deterministic and derived from what the job *does*, not from its BullMQ
  /// id — a retry gets a new attempt but must produce the same key.
  /// e.g. `email:invoice-issued:<invoiceId>`
  jobKey String @unique @map("job_key")

  state JobState @default(CLAIMED)

  tenantId String? @map("tenant_id") @db.Uuid

  claimedAt   DateTime  @default(now()) @map("claimed_at")
  completedAt DateTime? @map("completed_at")

  @@index([state])
  @@map("processed_jobs")
}

/// Jobs that exhausted their retries.
///
/// The backlog's requirement is that these are not silently dropped. BullMQ
/// keeps failed jobs in Redis, but Redis is a cache that gets flushed and
/// resized — a durable row is what makes "which invoices never got emailed?"
/// answerable weeks later.
model DeadLetterJob {
  id String @id @default(uuid()) @db.Uuid

  queueName String @map("queue_name")
  jobName   String @map("job_name")
  /// BullMQ's own id, so the failed job can be found in Redis while it lasts.
  jobId     String @map("job_id")

  /// The full job payload, so it can be replayed by hand after a fix.
  payload Json

  failedReason String  @map("failed_reason")
  stackTrace   String? @map("stack_trace")
  attempts     Int

  /// Carried so the whole journey stays greppable, including this end of it.
  correlationId String? @map("correlation_id")
  tenantId      String? @map("tenant_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([queueName])
  @@index([tenantId])
  @@map("dead_letter_jobs")
}
