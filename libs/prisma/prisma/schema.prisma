// Sprint 1: Tenant, User, RefreshToken.
// Contract/Client/Milestone land in Sprint 2, Invoice/Payment in Sprint 3.

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  // Prisma 7's generator defaults to ESM, which emits `import.meta.url` and
  // makes Node treat the compiled file as an ES module. Nest's DI and
  // decorator metadata need CommonJS, so pin the format here.
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

// Prisma 7 no longer accepts `url` here. The connection string is supplied at
// runtime through the pg driver adapter (see prisma.service.ts) and to the CLI
// through prisma.config.ts — one less place for a secret to sit in source.
datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  // Drives tax calculation in the Sprint 3 CreateInvoiceCommand.
  country   String   @db.Char(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String
  passwordHash String   @map("password_hash")
  role         UserRole @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  // Email is unique *per tenant*, not globally: the same person may hold an
  // account in two tenants. A global unique here would leak tenant membership
  // via signup errors.
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// One row per issued refresh token, so tokens can be rotated and revoked.
///
/// A JWT is self-contained and cannot be un-issued — the only way to revoke one
/// is to check it against server-side state. That is what this table is for,
/// and it is why refresh tokens are long-lived while access tokens are not:
/// the short access-token TTL bounds how long a revoked session stays usable.
model RefreshToken {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid

  /// SHA-256 of the token, never the token itself. A database leak must not
  /// hand out usable sessions. Hashing is cheap here (unlike passwords)
  /// because the input is already high-entropy — no brute-force to slow down.
  tokenHash String @unique @map("token_hash")

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  /// Set when this token is rotated out, pointing at its replacement. Presenting
  /// an already-rotated token means it leaked, and the whole chain is revoked.
  replacedById String? @unique @map("replaced_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("refresh_tokens")
}
